[resource]
script = ExtResource("1_map")
id = &"map_04"
display_name = "Split Sundae"
path_points = PackedVector2Array(-40, 280, 360, 280, 360, 500, 160, 500, 160, 740, 500, 740, 500, 940, 360, 940, 360, 1020)
pad_positions = PackedVector2Array(200, 390, 520, 390, 660, 390, 630, 780, 280, 860, 520, 1040)
starting_coins = 110
starting_lives = 18
waves = Array[ExtResource("2_wave")]([SubResource("wave1"), SubResource("wave2"), SubResource("wave3"), SubResource("wave4"), SubResource("wave5"), SubResource("wave6"), SubResource("wave7"), SubResource("wave8"), SubResource("wave9"), SubResource("wave10"), SubResource("wave11"), SubResource("wave12")])
endless_hp_growth = 1.15
endless_count_growth = 1.07
endless_speed_growth = 1.02
river_position = Vector2(360, 620)
river_scale = Vector2(0.95, 0.4)
bridge_position = Vector2(160, 620)
bridge_scale = Vector2(0.55, 0.55)
ornaments = Array[ExtResource("orn_script")]([SubResource("orn_1"), SubResource("orn_2")])
lanes = Array[ExtResource("lane_script")]([SubResource("lane_left"), SubResource("lane_right")])
